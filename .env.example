DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require
BASE_URL=http://127.0.0.1:8000
RATE_LIMIT_STORAGE_URI=memory://
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Number of trusted reverse proxies in front of this app. 0 = trust nothing,
# use the raw socket IP (safe default for local dev / no proxy). Set to 1
# when deployed behind a single edge proxy (e.g. Render) so rate limiting
# uses the real client IP from X-Forwarded-For instead of the proxy's IP.
TRUSTED_PROXY_HOPS=0
